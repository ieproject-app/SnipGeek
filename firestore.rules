
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'iwan.efndi@gmail.com';
    }

    // --- COLLECTION RULES ---

    // Public Rules (Read Only)
    match /blogPosts_published/{blogPostId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    match /notes_published/{noteId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    // Unique Number Generator Rules
    match /availableNumbers/{numberId} {
      // Allow reading stock availability for logged in users
      allow get, list: if isSignedIn();
      
      // Allow admin to populate data
      allow write: if isAdmin();

      // Only allow normal users updating the isUsed status
      allow update: if isSignedIn() 
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isUsed', 'assignedTo', 'assignedDate']);
    }

    match /userGenerationLimits/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
