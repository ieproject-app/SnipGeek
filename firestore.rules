
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    // --- COLLECTION RULES ---

    match /roles_admin/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /blogPosts_published/{blogPostId} {
      allow get, list: if true;
      allow create: if isAdmin() && request.resource.data.id == blogPostId;
      allow update: if isExistingAdmin() && request.resource.data.authorId == resource.data.authorId;
      allow delete: if isExistingAdmin();
    }

    match /blogPosts_drafts/{blogPostId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin() && request.resource.data.id == blogPostId;
      allow update: if isExistingAdmin() && request.resource.data.authorId == resource.data.authorId;
      allow delete: if isExistingAdmin();
    }

    match /notes_published/{noteId} {
      allow get, list: if true;
      allow create: if isAdmin() && request.resource.data.id == noteId;
      allow update, delete: if isExistingAdmin();
    }

    match /notes_drafts/{noteId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin() && request.resource.data.id == noteId;
      allow update, delete: if isExistingAdmin();
    }

    match /authors/{authorId} {
      allow get, list: if true;
      allow create: if isAdmin() && request.resource.data.id == authorId;
      allow update: if isExistingAdmin();
      allow delete: if isExistingAdmin();
    }

    match /tags/{tagId} {
      allow get, list: if true;
      allow create: if isAdmin() && request.resource.data.id == tagId;
      allow update: if isExistingAdmin();
      allow delete: if isExistingAdmin();
    }
  }
}
