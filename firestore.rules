
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SNIPGEEK SECURITY RULES
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'iwan.efndi@gmail.com';
    }

    // Number Generator Rules
    match /availableNumbers/{numberId} {
      // Users can see stock to display matrix
      allow read: if isSignedIn();
      
      // Admin (Iwan) can populate/delete data
      allow create, delete: if isAdmin();
      
      // Users can only mark a number as used if it's currently free
      // They must set assignedTo to themselves
      allow update: if isSignedIn() 
        && resource.data.isUsed == false 
        && request.resource.data.isUsed == true
        && (request.resource.data.assignedTo == request.auth.token.email || isAdmin());
    }

    match /userGenerationLimits/{userId} {
      // Users can manage their own quota
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      // Admin can check/manage anyone's quota
      allow read, write: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
